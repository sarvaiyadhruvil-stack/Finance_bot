# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this file to .env and populate with your real values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Binance Futures Testnet Credentials ──────────────────────────────────────
# Generate from: https://testnet.binancefuture.com/  → Account → API Management
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# ── API Settings (optional — defaults shown) ─────────────────────────────────
# Override the REST base URL (default is the Futures Testnet).
BINANCE_BASE_URL=https://testnet.binancefuture.com

# HTTP request timeout in seconds.
REQUEST_TIMEOUT=10

# recvWindow parameter in milliseconds (how long the server accepts the request).
RECV_WINDOW=5000

# ── Logging ───────────────────────────────────────────────────────────────────
# Minimum level written to logs/trading_bot.log (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=DEBUG
